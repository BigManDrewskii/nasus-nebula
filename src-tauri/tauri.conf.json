{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nasus",
  "version": "0.1.0",
  "identifier": "im.nasus.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nasus",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 16 }
      }
    ],
      "security": {
        "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' ipc: http: https:;"
      }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BigManDrewskii/nasus/releases/latest/download/update.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgwRDFGN0NFNDlFRkEzMjQKUldSWDVVeTgxV1R0VzZVSm1CVWp4Q05zUkFUV0I4TjZ4Z25qZ0JkY2daZzZzZ3JkZk5HUEpZSmEK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "sidecar/package.json": "sidecar/package.json",
      "sidecar/index.js": "sidecar/index.js"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
