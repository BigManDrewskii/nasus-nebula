{
  "manifest_version": 3,
  "name": "Nasus Browser Bridge",
  "version": "1.1.0",
  "description": "Gives Nasus AI agent permission to control your browser tabs.",
  "permissions": [
    "debugger",
    "tabs",
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Nasus Browser Bridge",
    "default_popup": "popup.html"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://localhost:5173/*",
      "http://localhost:3000/*",
      "https://localhost/*",
      "https://localhost:5173/*",
      "https://localhost:3000/*",
      "http://127.0.0.1/*",
      "http://127.0.0.1:5173/*",
      "http://127.0.0.1:3000/*",
      "https://127.0.0.1/*",
      "https://127.0.0.1:5173/*",
      "https://127.0.0.1:3000/*",
      "https://nasus.app/*",
      "https://*.nasus.app/*"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
